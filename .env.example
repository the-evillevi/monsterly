VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_MONSTERLY_ORGANIZATION_ID=

# Auth mode. Leave UNSET in production (and never set it in Vercel): the app
# then requires a Google sign-in with active organization membership before it
# syncs. Set to `anon` for local dev only, where it pairs with the permissive
# anon grants in supabase/seed.sql so `supabase start` needs no Google
# credentials.
VITE_MONSTERLY_AUTH_MODE=
